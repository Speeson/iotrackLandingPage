{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "destination": "/iotrack",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/iotrack",
      "destination": "/"
    },
    {
      "source": "/iotrack/:path*",
      "destination": "/:path*"
    }
  ]
}
