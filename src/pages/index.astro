---
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL;
---

<BaseLayout>
  <div class="bg-layer">
    <div class="graphene-sky">
      <div class="hex-field" id="hexField" aria-hidden="true"></div>
    </div>
    <div class="hex-vignette"></div>
  </div>

  <div class="scroll-progress" aria-hidden="true"></div>

  <header class="site-header glass">
    <div class="container header-inner">
      <a href="#top" class="brand">
        <span class="brand-mark" aria-hidden="true">
          <span class="brand-hex">
            <img src={`${basePath}assets/logos/iotrack.png`} alt="" loading="lazy" />
          </span>
        </span>
        <span class="brand-wordmark">IoTrack</span>
      </a>

      <nav class="nav-links" aria-label="Primary">
        <a href="#solution" data-i18n="nav_solution">Flujo</a>
        <a href="#app" data-i18n="nav_app">App</a>
        <a href="#integration" data-i18n="nav_integration">Integraciones</a>
        <a href="#architecture" data-i18n="nav_architecture">Arquitectura</a>
        <a href="#project" data-i18n="nav_project">Proyecto</a>
        <a href="#author" data-i18n="nav_author">Autor</a>
      </nav>

      <div class="header-controls">
        <div class="lang-switch glass-light" role="group" aria-label="Language selector">
          <button class="lang-btn is-active" data-lang-btn="es">ES</button>
          <button class="lang-btn" data-lang-btn="en">EN</button>
        </div>
        <button class="theme-btn glass-light" id="themeToggle" type="button" aria-label="Toggle theme">
          <span class="theme-thumb" aria-hidden="true"></span>
          <svg class="theme-icon sun-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="m4.93 4.93 1.41 1.41"></path>
            <path d="m17.66 17.66 1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="m6.34 17.66-1.41 1.41"></path>
            <path d="m19.07 4.93-1.41 1.41"></path>
          </svg>
          <svg class="theme-icon moon-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M20.7 14.4A8 8 0 0 1 9.6 3.3 8.6 8.6 0 1 0 20.7 14.4Z"></path>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <main id="top">
    <section class="hero container reveal snap-section">
      <h1 class="hero-app-title" data-i18n="hero_app_name">IoTrack</h1>
      <p class="hero-subtitle" data-i18n="hero_title">Controla stock, eventos y trazabilidad en tiempo real</p>
      <p class="eyebrow" data-i18n="hero_badge">Inventario inteligente para equipos que necesitan control real</p>
      <p class="hero-copy" data-i18n="hero_copy">
        IoTrack digitaliza el inventario para centralizar productos, movimientos y eventos en una sola herramienta
        conectada entre móvil y backend.
      </p>
      <p class="hero-value" data-i18n="hero_value">
        Reduce errores manuales, acelera entradas y salidas y mantiene el stock siempre trazable antes de que los
        fallos lleguen a la operación.
      </p>
      <div class="hero-actions">
        <a class="btn-primary" href="#solution" data-i18n="hero_cta_primary">Explorar plataforma</a>
        <a class="btn-secondary" href="#app" data-i18n="hero_cta_secondary">Ver la app</a>
      </div>
      <div class="hero-panels">
        <article class="glass panel reveal" data-stagger="0">
          <span class="panel-label" data-i18n="hero_panel_1_label">Inventario inteligente</span>
          <strong class="panel-value panel-value-text" data-i18n="hero_panel_1_value">Productos, stock y movimientos trazables</strong>
        </article>
        <article class="glass panel reveal" data-stagger="1">
          <span class="panel-label" data-i18n="hero_panel_2_label">Eventos IoT simulados</span>
          <strong class="panel-value panel-value-text" data-i18n="hero_panel_2_value">Sensores, cola asíncrona y workers</strong>
        </article>
        <article class="glass panel reveal" data-stagger="2">
          <span class="panel-label" data-i18n="hero_panel_3_label">Android + Backend</span>
          <strong class="panel-value panel-value-text" data-i18n="hero_panel_3_value">Escaneo, etiquetas, API y base de datos</strong>
        </article>
      </div>
    </section>

    <section id="solution" class="container section reveal snap-section">
      <div class="section-heading flow-heading">
        <p class="eyebrow flow-eyebrow" data-i18n="solution_badge">Flujo operativo IoTrack</p>
        <h2 data-i18n="solution_title">Una sola fuente de verdad para tu inventario</h2>
      </div>
      <div class="flow-track glass reveal">
        <article class="flow-node">
          <div class="flow-icon" aria-hidden="true">
            <svg viewBox="0 0 64 64" focusable="false">
              <rect x="10" y="16" width="44" height="32" rx="8"></rect>
              <circle cx="32" cy="32" r="8"></circle>
              <path d="M20 12h24"></path>
            </svg>
          </div>
          <h3 class="flow-title" data-i18n="solution_step1_title">Captura</h3>
          <p class="flow-body" data-i18n="solution_step1_body">Movimientos por escaneo de barras y eventos de sensores simulados.</p>
        </article>
        <div class="flow-link" aria-hidden="true">
          <span class="flow-arrow">></span>
        </div>
        <article class="flow-node">
          <div class="flow-icon" aria-hidden="true">
            <svg viewBox="0 0 64 64" focusable="false">
              <rect x="18" y="18" width="28" height="28" rx="6"></rect>
              <rect x="26" y="26" width="12" height="12" rx="3"></rect>
              <path d="M26 8v10M38 8v10M26 46v10M38 46v10"></path>
              <path d="M8 26h10M8 38h10M46 26h10M46 38h10"></path>
              <path d="M32 14v4M32 46v4M14 32h4M46 32h4"></path>
            </svg>
          </div>
          <h3 class="flow-title" data-i18n="solution_step2_title">Procesa</h3>
          <p class="flow-body" data-i18n="solution_step2_body">Cola asíncrona con workers para idempotencia, reintentos y trazabilidad.</p>
        </article>
        <div class="flow-link" aria-hidden="true">
          <span class="flow-arrow">></span>
        </div>
        <article class="flow-node">
          <div class="flow-icon" aria-hidden="true">
            <svg viewBox="0 0 64 64" focusable="false">
              <rect x="10" y="12" width="44" height="40" rx="8"></rect>
              <path d="M21 25h14"></path>
              <path d="M21 39h10"></path>
              <circle cx="45" cy="25" r="5"></circle>
              <path d="m41 39 4 4 8-10"></path>
            </svg>
          </div>
          <h3 class="flow-title" data-i18n="solution_step3_title">Decide</h3>
          <p class="flow-body" data-i18n="solution_step3_body">Alertas de bajo stock, reportes de turnover y auditoría completa por rol.</p>
        </article>
      </div>
    </section>

    <section id="benefits" class="container section reveal snap-section">
      <div class="section-heading benefits-heading">
        <p class="eyebrow" data-i18n="benefits_badge">Propuesta de valor</p>
        <h2 data-i18n="benefits_title">Menos errores, más rapidez y un inventario siempre bajo control</h2>
      </div>
      <div class="benefits-grid">
        <article class="glass benefit-card reveal" data-stagger="0">
          <h3 data-i18n="benefit_1_title">Reduce errores manuales</h3>
          <p data-i18n="benefit_1_body">Cada movimiento queda registrado con contexto, usuario y trazabilidad para evitar desajustes de stock.</p>
        </article>
        <article class="glass benefit-card reveal" data-stagger="1">
          <h3 data-i18n="benefit_2_title">Acelera las operaciones</h3>
          <p data-i18n="benefit_2_body">Escaneo con cámara, confirmación de movimientos y sincronización desde móvil para trabajar más rápido.</p>
        </article>
        <article class="glass benefit-card reveal" data-stagger="2">
          <h3 data-i18n="benefit_3_title">Trazabilidad completa</h3>
          <p data-i18n="benefit_3_body">Productos, eventos, alertas y auditoría quedan conectados para saber qué pasó, cuándo y por qué.</p>
        </article>
        <article class="glass benefit-card reveal" data-stagger="3">
          <h3 data-i18n="benefit_4_title">Anticípate al problema</h3>
          <p data-i18n="benefit_4_body">Alertas de stock bajo y reportes ayudan a tomar decisiones antes de llegar a roturas o cuellos de botella.</p>
        </article>
      </div>
    </section>

    <section id="app" class="container section reveal snap-section" data-snap-style="tight">
      <div class="section-heading">
        <p class="eyebrow" data-i18n="app_badge">App Android</p>
        <h2 data-i18n="app_title">Inventario operable desde el móvil</h2>
      </div>
      <div class="app-showcase">
        <article class="glass phone-frame reveal">
          <div class="phone-speaker" aria-hidden="true"></div>
          <div class="phone-screen app-screenshot-frame">
            <img
              id="appPreviewImage"
              src={`${basePath}assets/logos/screen.png`}
              data-default-preview-dark={`${basePath}assets/logos/screen.png`}
              data-default-preview-light={`${basePath}assets/logos/screen.png`}
              alt="Pantalla de login de IoTrack en Android"
              loading="lazy"
            />
          </div>
        </article>
        <div class="capability-grid">
          <article
            class="glass capability-card reveal"
            data-stagger="0"
            data-preview-dark={`${basePath}assets/logos/dark/screen1.png`}
            data-preview-light={`${basePath}assets/logos/light/screen1.png`}
          >
            <span class="card-index">01</span>
            <h3 data-i18n="app_card_1_title">Escaneo con cámara</h3>
            <p data-i18n="app_card_1_body">CameraX y ML Kit leen códigos de barras para abrir el flujo de movimiento.</p>
          </article>
          <article
            class="glass capability-card reveal"
            data-stagger="1"
            data-preview-dark={`${basePath}assets/logos/dark/screen2.png`}
            data-preview-light={`${basePath}assets/logos/light/screen2.png`}
          >
            <span class="card-index">02</span>
            <h3 data-i18n="app_card_2_title">Operación offline</h3>
            <p data-i18n="app_card_2_body">Room mantiene caché local, cola de errores y reintentos cuando vuelve la conexión.</p>
          </article>
          <article
            class="glass capability-card reveal"
            data-stagger="2"
            data-preview-dark={`${basePath}assets/logos/dark/screen3.png`}
            data-preview-light={`${basePath}assets/logos/light/screen3.png`}
          >
            <span class="card-index">03</span>
            <h3 data-i18n="app_card_3_title">Stock y alertas</h3>
            <p data-i18n="app_card_3_body">Pantallas para productos, stocks, eventos, rotación, umbrales y alertas.</p>
          </article>
          <article
            class="glass capability-card reveal"
            data-stagger="3"
            data-preview-dark={`${basePath}assets/logos/dark/screen4.png`}
            data-preview-light={`${basePath}assets/logos/light/screen4.png`}
          >
            <span class="card-index">04</span>
            <h3 data-i18n="app_card_4_title">Etiquetas Bluetooth</h3>
            <p data-i18n="app_card_4_body">Impresión de etiquetas desde Android mediante integración con SDK de NIIMBOT.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="iot" class="container section reveal snap-section">
      <div class="section-heading">
        <p class="eyebrow" data-i18n="iot_badge">Sensores IoT simulados</p>
        <h2 data-i18n="iot_title">Eventos simulados, comportamiento de sistema real</h2>
      </div>
      <div class="iot-grid">
        <article class="glass iot-card reveal" data-stagger="0">
          <h3 data-i18n="iot_card_1_title">Eventos desacoplados</h3>
          <p data-i18n="iot_card_1_body">La API registra eventos de entrada, salida o ajuste y los deja listos para procesarse.</p>
        </article>
        <article class="glass iot-card reveal" data-stagger="1">
          <h3 data-i18n="iot_card_2_title">Workers y cola</h3>
          <p data-i18n="iot_card_2_body">Redis y Celery ejecutan el procesamiento en segundo plano con reintentos.</p>
        </article>
        <article class="glass iot-card reveal" data-stagger="2">
          <h3 data-i18n="iot_card_3_title">Estados trazables</h3>
          <p data-i18n="iot_card_3_body">Cada evento puede quedar pendiente, procesado o fallido con información de error.</p>
        </article>
        <article class="glass iot-card reveal" data-stagger="3">
          <h3 data-i18n="iot_card_4_title">Idempotencia</h3>
          <p data-i18n="iot_card_4_body">Las claves idempotentes ayudan a evitar duplicados cuando hay reintentos.</p>
        </article>
      </div>
    </section>

    <section id="integration" class="container section reveal snap-section">
      <div class="section-heading">
        <p class="eyebrow" data-i18n="integration_badge">Integraciones</p>
        <h2 data-i18n="integration_title">Etiquetado físico conectado al inventario</h2>
      </div>
      <article class="glass integration-card reveal">
        <div class="niimbot-mark">
          <img src={`${basePath}assets/logos/niimbot.png`} alt="NIIMBOT" loading="lazy" />
          <strong>NIIMBOT</strong>
          <span>SDK</span>
        </div>
        <div class="integration-copy">
          <h3 data-i18n="integration_card_title">Impresión Bluetooth desde Android</h3>
          <p data-i18n="integration_card_body">
            IoTrack integra el SDK oficial de NIIMBOT para imprimir etiquetas desde la app y cerrar el flujo entre producto digital y etiqueta física.
          </p>
          <p class="legal-note" data-i18n="integration_note">
            Uso académico, demostrativo y sin finalidad comercial. IoTrack no está afiliado, patrocinado ni respaldado oficialmente por NIIMBOT.
          </p>
        </div>
      </article>
    </section>

    <section id="architecture" class="container section reveal snap-section">
      <div class="section-heading">
        <p class="eyebrow" data-i18n="architecture_badge">Arquitectura</p>
        <h2 data-i18n="architecture_title">Una app móvil conectada a un backend auditable</h2>
      </div>
      <div class="architecture-grid">
        <article class="glass arch-card reveal" data-stagger="0">
          <span class="tech-pill">Kotlin</span>
          <div class="tech-icon tech-icon--kotlin" aria-hidden="true">
            <svg viewBox="0 0 48 48" focusable="false">
              <defs>
                <linearGradient id="kotlinGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#7f52ff"></stop>
                  <stop offset="55%" stop-color="#ff6b81"></stop>
                  <stop offset="100%" stop-color="#ffb300"></stop>
                </linearGradient>
              </defs>
              <path fill="url(#kotlinGrad)" d="M8 8h32L24 24 40 40H8l16-16Z"></path>
            </svg>
          </div>
          <h3 data-i18n="architecture_layer_1">Android</h3>
          <p data-i18n="architecture_layer_1_body">Retrofit, OkHttp, Room, CameraX, ML Kit, sesiones persistentes y soporte offline.</p>
        </article>
        <article class="glass arch-card reveal" data-stagger="1">
          <span class="tech-pill">FastAPI</span>
          <div class="tech-icon tech-icon--fastapi" aria-hidden="true">
            <img src={`${basePath}assets/logos/fastapi.webp`} alt="" loading="lazy" />
          </div>
          <h3 data-i18n="architecture_layer_2">API REST</h3>
          <p data-i18n="architecture_layer_2_body">JWT, roles USER/MANAGER/ADMIN, OpenAPI, validaciones y reglas de dominio.</p>
        </article>
        <article class="glass arch-card reveal" data-stagger="2">
          <span class="tech-pill">PostgreSQL</span>
          <div class="tech-icon tech-icon--postgres" aria-hidden="true">
            <img src={`${basePath}assets/logos/postgresql.png`} alt="" loading="lazy" />
          </div>
          <h3 data-i18n="architecture_layer_3">Datos</h3>
          <p data-i18n="architecture_layer_3_body">SQLAlchemy, Alembic, productos, stocks, movimientos, eventos, auditoría e importaciones.</p>
        </article>
        <article class="glass arch-card reveal" data-stagger="3">
          <span class="tech-pill">Redis + Celery</span>
          <div class="tech-icon tech-icon--redis" aria-hidden="true">
            <img src={`${basePath}assets/logos/redis.webp`} alt="" loading="lazy" />
          </div>
          <h3 data-i18n="architecture_layer_4">Procesamiento</h3>
          <p data-i18n="architecture_layer_4_body">Workers, Celery Beat, alertas de stock bajo, reintentos y jobs programados.</p>
        </article>
        <article class="glass arch-card reveal" data-stagger="4">
          <span class="tech-pill">CI/CD</span>
          <div class="tech-icon tech-icon--docker" aria-hidden="true">
            <img src={`${basePath}assets/logos/docker.png`} alt="" loading="lazy" />
          </div>
          <h3 data-i18n="architecture_layer_5">Calidad</h3>
          <p data-i18n="architecture_layer_5_body">Pytest, contract tests, snapshot OpenAPI, Docker y GitHub Actions.</p>
        </article>
        <article class="glass arch-card reveal" data-stagger="5">
          <span class="tech-pill">Grafana</span>
          <div class="tech-icon tech-icon--grafana" aria-hidden="true">
            <img src={`${basePath}assets/logos/grafana.webp`} alt="" loading="lazy" />
          </div>
          <h3 data-i18n="architecture_layer_6">Observabilidad</h3>
          <p data-i18n="architecture_layer_6_body">Healthcheck, métricas Prometheus y paneles para seguimiento técnico.</p>
        </article>
      </div>
    </section>

    <section id="project" class="container section reveal snap-section">
      <div class="section-heading">
        <p class="eyebrow" data-i18n="project_badge">Proyecto académico</p>
        <h2 data-i18n="project_title">Desarrollado con Scrum en tres sprints</h2>
      </div>
      <div class="project-grid">
        <article class="glass sprint-card reveal" data-stagger="0">
          <span class="sprint-number">Sprint 1</span>
          <h3 data-i18n="sprint_1_title">Base funcional</h3>
          <p data-i18n="sprint_1_body">CRUD de productos y stock, escaneo móvil, autenticación y primeros eventos.</p>
        </article>
        <article class="glass sprint-card reveal" data-stagger="1">
          <span class="sprint-number">Sprint 2</span>
          <h3 data-i18n="sprint_2_title">Procesamiento y UX</h3>
          <p data-i18n="sprint_2_body">Workers, alertas, reportes, cola offline, pantallas Android y feedback de sincronizacion.</p>
        </article>
        <article class="glass sprint-card reveal" data-stagger="2">
          <span class="sprint-number">Sprint 3</span>
          <h3 data-i18n="sprint_3_title">Calidad y defensa</h3>
          <p data-i18n="sprint_3_body">Importaciones CSV, auditoría, OpenAPI, tests de contrato, CI/CD y observabilidad.</p>
        </article>
      </div>
    </section>

    <section id="author" class="container section reveal snap-section">
      <article class="glass cta-card academic-card reveal">
        <a class="author-school-link" href="https://pro2fp.es" target="_blank" rel="noreferrer" aria-label="Visitar Pro2FP">
          <img src={`${basePath}assets/logos/pro2fp.png`} alt="Pro2FP" loading="lazy" />
        </a>
        <p class="eyebrow" data-i18n="cta_badge">Sobre el autor</p>
        <h2 data-i18n="cta_title">IoTrack nace como proyecto de 2º DAM en Pro2FP</h2>
        <p data-i18n="cta_body">
          Proyecto educativo desarrollado por Esteban Garcés Pérez para demostrar una solución completa de inventario, sensores simulados, app Android y backend desplegable.
        </p>
        <div class="cta-actions">
          <a class="btn-primary" href="https://speeson.github.io/CVLandingPage/" target="_blank" rel="noreferrer" data-i18n="cta_primary">Ver mi landing personal</a>
          <a class="btn-secondary btn-with-icon" href="https://github.com/Speeson" target="_blank" rel="noreferrer">
            <svg class="btn-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M12 2.3a9.8 9.8 0 0 0-3.1 19.1c.5.1.7-.2.7-.5v-1.8c-2.9.6-3.5-1.2-3.5-1.2-.5-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 .1 1.6 1.1 1.6 1.1.9 1.5 2.4 1.1 3 .8.1-.7.4-1.1.7-1.4-2.3-.3-4.7-1.2-4.7-5A3.9 3.9 0 0 1 6.7 8.7c-.1-.3-.5-1.3.1-2.8 0 0 .9-.3 2.9 1a9.7 9.7 0 0 1 5.3 0c2-1.3 2.9-1 2.9-1 .6 1.5.2 2.5.1 2.8a3.9 3.9 0 0 1 1 2.7c0 3.9-2.4 4.7-4.7 5 .4.3.8 1 .8 2v2.5c0 .3.2.6.8.5A9.8 9.8 0 0 0 12 2.3Z"></path>
            </svg>
            <span data-i18n="cta_secondary">Ver GitHub</span>
          </a>
        </div>
      </article>
    </section>
  </main>

  <footer class="container footer">
    <p>IoTrack Landing</p>
    <p data-i18n="footer_copy">Sistema de inventariado con sensores IoT simulados.</p>
  </footer>

  <script is:inline>
    const dictionary = {
      es: {
        nav_solution: "Flujo",
        nav_app: "App",
        nav_integration: "Integraciones",
        nav_architecture: "Arquitectura",
        nav_project: "Proyecto",
        nav_author: "Autor",
        hero_badge: "Inventario inteligente para equipos que necesitan control real",
        hero_app_name: "IoTrack",
        hero_title: "Controla stock, eventos y trazabilidad en tiempo real",
        hero_copy:
          "IoTrack digitaliza el inventario para centralizar productos, movimientos y eventos en una sola herramienta conectada entre móvil y backend.",
        hero_value:
          "Reduce errores manuales, acelera entradas y salidas y mantiene el stock siempre trazable antes de que los fallos lleguen a la operación.",
        hero_cta_primary: "Ver flujo operativo",
        hero_cta_secondary: "Ver la app",
        hero_panel_1_label: "Inventario inteligente",
        hero_panel_1_value: "Productos, stock y movimientos trazables",
        hero_panel_2_label: "Eventos IoT simulados",
        hero_panel_2_value: "Sensores, cola asíncrona y workers",
        hero_panel_3_label: "Android + Backend",
        hero_panel_3_value: "Escaneo, etiquetas, API y base de datos",
        solution_badge: "Flujo operativo IoTrack",
        solution_title: "Una sola fuente de verdad para tu inventario",
        solution_step1_title: "Captura",
