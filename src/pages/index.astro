---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <div class="bg-layer">
    <div class="graphene-sky">
      <div class="hex-field" id="hexField" aria-hidden="true"></div>
    </div>
    <div class="hex-vignette"></div>
  </div>

  <div class="scroll-progress" aria-hidden="true"></div>

  <header class="site-header glass">
    <div class="container header-inner">
      <a href="#top" class="brand">
        <span class="brand-dot"></span>
        <span>IoTrack</span>
      </a>

      <nav class="nav-links" aria-label="Primary">
        <a href="#solution" data-i18n="nav_solution">Solucion</a>
        <a href="#features" data-i18n="nav_features">Funciones</a>
        <a href="#architecture" data-i18n="nav_architecture">Arquitectura</a>
        <a href="#cta" data-i18n="nav_contact">Contacto</a>
      </nav>

      <div class="header-controls">
        <div class="lang-switch glass-light" role="group" aria-label="Language selector">
          <button class="lang-btn is-active" data-lang-btn="es">ES</button>
          <button class="lang-btn" data-lang-btn="en">EN</button>
        </div>
        <button class="theme-btn glass-light" id="themeToggle" type="button" aria-label="Toggle theme">
          <span class="theme-thumb" aria-hidden="true"></span>
          <svg class="theme-icon sun-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="m4.93 4.93 1.41 1.41"></path>
            <path d="m17.66 17.66 1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="m6.34 17.66-1.41 1.41"></path>
            <path d="m19.07 4.93-1.41 1.41"></path>
          </svg>
          <svg class="theme-icon moon-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M20.7 14.4A8 8 0 0 1 9.6 3.3 8.6 8.6 0 1 0 20.7 14.4Z"></path>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <main id="top">
    <section class="hero container reveal snap-section">
      <h1 class="hero-app-title" data-i18n="hero_app_name">IoTrack</h1>
      <p class="hero-subtitle" data-i18n="hero_title">Controla stock, eventos y trazabilidad en tiempo real</p>
      <p class="eyebrow" data-i18n="hero_badge">Inventario inteligente para equipos modernos</p>
      <p class="hero-copy" data-i18n="hero_copy">
        IoTrack conecta escaneo Android, API FastAPI, PostgreSQL y eventos IoT simulados para crear un flujo
        operativo robusto, auditable y preparado para escalar.
      </p>
      <div class="hero-actions">
        <a class="btn-primary" href="#solution" data-i18n="hero_cta_primary">Explorar plataforma</a>
        <a class="btn-secondary" href="#architecture" data-i18n="hero_cta_secondary">Ver arquitectura</a>
      </div>
      <div class="hero-panels">
        <article class="glass panel reveal" data-stagger="0">
          <span class="panel-label" data-i18n="hero_panel_1_label">Eventos procesados</span>
          <strong class="panel-value"><span data-counter="12500">12.5K</span></strong>
        </article>
        <article class="glass panel reveal" data-stagger="1">
          <span class="panel-label" data-i18n="hero_panel_2_label">Disponibilidad API</span>
          <strong class="panel-value"><span data-counter="99.9">99.9</span>%</strong>
        </article>
        <article class="glass panel reveal" data-stagger="2">
          <span class="panel-label" data-i18n="hero_panel_3_label">Latencia media</span>
          <strong class="panel-value"><span data-counter="85">85</span>ms</strong>
        </article>
      </div>
    </section>

    <section id="solution" class="container section reveal snap-section">
      <div class="section-heading flow-heading">
        <p class="eyebrow flow-eyebrow" data-i18n="solution_badge">Flujo operativo IoTrack</p>
        <h2 data-i18n="solution_title">Una sola fuente de verdad para tu inventario</h2>
      </div>
      <div class="flow-track glass reveal">
        <article class="flow-node">
          <div class="flow-icon" aria-hidden="true">
            <svg viewBox="0 0 64 64" focusable="false">
              <rect x="10" y="16" width="44" height="32" rx="8"></rect>
              <circle cx="32" cy="32" r="8"></circle>
              <path d="M20 12h24"></path>
            </svg>
          </div>
          <h3 class="flow-title" data-i18n="solution_step1_title">Captura</h3>
          <p class="flow-body" data-i18n="solution_step1_body">Movimientos por escaneo de barras y eventos de sensores simulados.</p>
        </article>
        <div class="flow-link" aria-hidden="true">
          <span class="flow-arrow">></span>
        </div>
        <article class="flow-node">
          <div class="flow-icon" aria-hidden="true">
            <svg viewBox="0 0 64 64" focusable="false">
              <rect x="12" y="14" width="40" height="36" rx="6"></rect>
              <path d="M22 24h20M22 32h12M22 40h16"></path>
              <circle cx="46" cy="40" r="5"></circle>
            </svg>
          </div>
          <h3 class="flow-title" data-i18n="solution_step2_title">Procesa</h3>
          <p class="flow-body" data-i18n="solution_step2_body">Cola asyncrona con workers para idempotencia, reintentos y trazabilidad.</p>
        </article>
        <div class="flow-link" aria-hidden="true">
          <span class="flow-arrow">></span>
        </div>
        <article class="flow-node">
          <div class="flow-icon" aria-hidden="true">
            <svg viewBox="0 0 64 64" focusable="false">
              <circle cx="32" cy="32" r="18"></circle>
              <path d="M32 20v12l8 4M20 42l6-6M44 42l-6-6"></path>
            </svg>
          </div>
          <h3 class="flow-title" data-i18n="solution_step3_title">Decide</h3>
          <p class="flow-body" data-i18n="solution_step3_body">Alertas de bajo stock, reportes de turnover y auditoria completa por rol.</p>
        </article>
      </div>
    </section>

    <section id="features" class="container section reveal snap-section">
      <div class="section-heading">
        <p class="eyebrow" data-i18n="features_badge">Capacidades clave</p>
        <h2 data-i18n="features_title">Tecnologia orientada a operaciones reales</h2>
      </div>
      <div class="feature-grid">
        <article class="glass feature-card reveal" data-stagger="0">
          <h3 data-i18n="feature_1_title">Auth + Roles</h3>
          <p data-i18n="feature_1_body">JWT con permisos USER, MANAGER y ADMIN en endpoints de negocio.</p>
        </article>
        <article class="glass feature-card reveal" data-stagger="1">
          <h3 data-i18n="feature_2_title">Android Productivo</h3>
          <p data-i18n="feature_2_body">Escaneo CameraX/ML Kit, cola offline y soporte de impresion de etiquetas.</p>
        </article>
        <article class="glass feature-card reveal" data-stagger="2">
          <h3 data-i18n="feature_3_title">Eventos IoT</h3>
          <p data-i18n="feature_3_body">Ingesta de eventos simulados y procesamiento asincrono con Redis + Celery.</p>
        </article>
        <article class="glass feature-card reveal" data-stagger="3">
          <h3 data-i18n="feature_4_title">Observabilidad</h3>
          <p data-i18n="feature_4_body">Health checks, metricas Prometheus y paneles de seguimiento en Grafana.</p>
        </article>
        <article class="glass feature-card reveal" data-stagger="4">
          <h3 data-i18n="feature_5_title">Import CSV</h3>
          <p data-i18n="feature_5_body">Importaciones controladas con cuarentena y aprobacion de lotes.</p>
        </article>
        <article class="glass feature-card reveal" data-stagger="5">
          <h3 data-i18n="feature_6_title">Auditoria</h3>
          <p data-i18n="feature_6_body">Trazabilidad por entidad, accion y usuario para defensa y compliance.</p>
        </article>
      </div>
    </section>

    <section id="architecture" class="container section reveal snap-section">
      <div class="section-heading">
        <p class="eyebrow" data-i18n="architecture_badge">Arquitectura</p>
        <h2 data-i18n="architecture_title">Diseno modular para escalar sin perder control</h2>
      </div>
      <div class="architecture-grid">
        <article class="glass arch-card reveal">
          <h3 data-i18n="architecture_layer_1">Frontend Android (Kotlin)</h3>
          <p data-i18n="architecture_layer_1_body">App con escaneo, sesiones persistentes y cache local para modo offline.</p>
        </article>
        <article class="glass arch-card reveal">
          <h3 data-i18n="architecture_layer_2">Backend FastAPI</h3>
          <p data-i18n="architecture_layer_2_body">API REST con JWT, validaciones, reglas de dominio y contrato OpenAPI.</p>
        </article>
        <article class="glass arch-card reveal">
          <h3 data-i18n="architecture_layer_3">Datos + Cola</h3>
          <p data-i18n="architecture_layer_3_body">PostgreSQL, SQLAlchemy, Redis, workers Celery y jobs programados.</p>
        </article>
      </div>
    </section>

    <section class="container section reveal metrics snap-section">
      <div class="section-heading">
        <p class="eyebrow" data-i18n="metrics_badge">Rendimiento</p>
        <h2 data-i18n="metrics_title">Indicadores de una operacion conectada</h2>
      </div>
      <div class="metrics-grid">
        <article class="glass metric-card reveal">
          <strong><span data-counter="240">240</span>+</strong>
          <p data-i18n="metrics_1">Endpoints y acciones cubiertas en API + app.</p>
        </article>
        <article class="glass metric-card reveal">
          <strong><span data-counter="5">5</span>m</strong>
          <p data-i18n="metrics_2">Frecuencia por defecto del escaneo de alertas de stock bajo.</p>
        </article>
        <article class="glass metric-card reveal">
          <strong><span data-counter="3">3</span></strong>
          <p data-i18n="metrics_3">Sprints de evolucion con foco en calidad y defensa tecnica.</p>
        </article>
      </div>
    </section>

    <section id="cta" class="container section reveal snap-section">
      <article class="glass cta-card">
        <p class="eyebrow" data-i18n="cta_badge">IoTrack</p>
        <h2 data-i18n="cta_title">Convierte inventario en decisiones con datos en tiempo real</h2>
        <p data-i18n="cta_body">
          Una landing disenada para mostrar una solucion completa: desde el escaneo en Android hasta analitica,
          alertas y auditoria en backend.
        </p>
        <div class="cta-actions">
          <a class="btn-primary" href="https://github.com/Speeson" target="_blank" rel="noreferrer" data-i18n="cta_primary">Ver proyectos</a>
          <a class="btn-secondary" href="mailto:esteban@example.com" data-i18n="cta_secondary">Contactar</a>
        </div>
      </article>
    </section>
  </main>

  <footer class="container footer">
    <p>IoTrack Landing</p>
    <p data-i18n="footer_copy">Sistema de inventariado con sensores IoT simulados.</p>
  </footer>

  <script is:inline>
    const dictionary = {
