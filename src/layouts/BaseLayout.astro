---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "IoTrack | Smart Inventory with Simulated IoT Sensors",
  description = "Landing page for IoTrack, an inventory management platform powered by simulated IoT sensor events."
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const savedTheme = localStorage.getItem("iotrack-theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = savedTheme || (prefersDark ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
